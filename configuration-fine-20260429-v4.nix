      # User-level Firefox (separate profile from system):
      programs.firefox.enable = true;

# Personal dev tools — keep only user-specific apps
      # (glib, dbus, mesa, alsa-lib, gtk3 already in systemPackages)
      home.packages = with pkgs; [
        zenity

