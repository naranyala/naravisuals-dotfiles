  # ═══════════════════════════════════════════════════════════
  # 10. SHELL ALIASES (system-wide)
  #
  # Available to all users and all shells (bash, zsh, fish).
  # For user-specific aliases, use home-manager (§15).
  #
  # FUTURE IMPROVEMENTS:
  #   • Add nix development aliases:
  #       nix-build-pkg = "nix-build -E 'with import <nixpkgs> {}; callPackage ./default.nix {}'";
  #   • Add container shortcuts:
  #       dclean = "docker system prune -af && docker volume prune -f";
  #   • Add a quick nixos config test:
  #       nix-test = "sudo nixos-rebuild dry-activate";
  # ═══════════════════════════════════════════════════════
  environment.shellAliases = {
    # NixOS helpers
    nix-switch = "sudo nixos-rebuild switch";
    nix-clean  = "sudo nix-collect-garbage -d";
    nix-config = "nano /etc/nixos/configuration.nix";

    # Windows-like shortcuts
    dir      = "ls -alh";
    cls      = "clear";
    explorer = "nautilus .";

    # NixOS config editing
    edit-nixos-ssd  = "sudo nvim /etc/nixos/configuration.nix";
    edit-nixos-ext  = "sudo nvim /media/naranyala/ext_root/etc/nixos/configuration.nix";

    # Project navigation (requires external drives mounted)
    goto-project-remote    = "cd /media/naranyala/Data/projects-remote";
    goto-project-agentic   = "cd /media/naranyala/Data/projects-agentic";
    goto-project-pi        = "cd /media/naranyala/Data/projects-pi-ext";
    mergepdf-cwd           = "bun /media/naranyala/Data/diskd-scripts/javascript/merge-all-pdf-in-current-dir.js";
    goto-diskd-bin         = "cd /media/naranyala/Data/diskd-binaries";
    battery-health         = "upower -i /org/freedesktop/UPower/devices/battery_BAT0";
    show-pi                = "bat ~/.pi/agent/settings.json";
    goto-config-opencode   = "cd ~/.config/opencode";
    goto-config-pi         = "cd ~/.pi/agent";
    goto-ai-runner         = "cd /media/naranyala/Data/diskd-binaries/llm-stack";
    goto-ai-models         = "cd /home/naranyala/.lmstudio/models/lmstudio-community";

    # Development
    gitlog = "git log --oneline --graph --decorate";
  };

  # ═══════════════════════════════════════════════════════
  # 11. ENVIRONMENT VARIABLES
  #
  # Set for ALL users. For user-specific vars, use home-manager.
  #
  # NOTE: NixOS automatically handles PKG_CONFIG_PATH, CFLAGS,
  # LDFLAGS, etc. via wrapGAppsHook4 and Nix wrappers. Setting
  # them manually usually causes conflicts. Only uncomment if
  # a specific non-Nix binary requires them.
  #
  # NPM_CONFIG_PREFIX: tells npm to install global packages
  # to ~/.npm-packages instead of the Nix store (which is
  # read-only). Add $HOME/.npm-packages/bin to PATH to use them.
  #
  # FUTURE IMPROVEMENTS:
  #   • Add `XDG_CONFIG_HOME = "$HOME/.config";` for apps that
  #     don't default to the XDG standard
  #   • Add `EDITOR = "nvim";` if neovim becomes your daily driver
  #   • Add `TERMINAL = "foot";` or your preferred terminal
  #   • Add `MOZ_ENABLE_WAYLAND = "1";` for Firefox Wayland native
  #   • Add `ELECTRON_OZONE_PLATFORM_HINT = "wayland";` for
  #     Electron apps (Discord, Slack, etc.) on Wayland
  # ═══════════════════════════════════════════════════════
  environment.variables = {
    EDITOR  = "nano";
    BROWSER = "firefox";
    NPM_CONFIG_PREFIX = "$HOME/.npm-packages";

    # Uncomment only if a specific non-Nix binary needs them:
    PKG_CONFIG_PATH  = "${pkgs.glib.dev}/lib/pkgconfig:${pkgs.glib.out}/lib/pkgconfig";
    CFLAGS           = "-I${pkgs.glib.dev}/include/glib-2.0 -I${pkgs.glib.dev}/lib/glib-2.0/include";
    LDFLAGS          = "-L${pkgs.glib.out}/lib -L${pkgs.gtk3.out}/lib";
    GIO_MODULE_DIR   = "${pkgs.glib.out}/lib/gio/modules";
    GST_PLUGIN_PATH  = "${pkgs.gst_all_1.gstreamer.out}/lib/gstreamer-1.0";
    MOZ_ENABLE_WAYLAND = "1";
    ELECTRON_OZONE_PLATFORM_HINT = "wayland";

    # cause failure to compile
    # LD_LIBRARY_PATH  = "${pkgs.glib.out}/lib:${pkgs.gtk3.out}/lib";
    # XDG_DATA_DIRS    = "${pkgs.gtk3.out}/share:${pkgs.glib.out}/share";
  };

  # Session PATH additions — directories added to $PATH for all users
  environment.sessionVariables = {
    PATH = [
      "$HOME/.npm-packages/bin"
      "$HOME/.local/bin"
      "$HOME/bin"
      "$HOME/.bun/bin"
      # WARNING: These depend on external drives being mounted.
      # If the drive isn't mounted, these entries are harmless but
      # produce "directory not found" warnings in some tools.
      # Consider systemd.automount for on-demand mounting:
      #   systemd.mounts = [{
      #     what = "/dev/disk/by-uuid/XXXX";
      #     where = "/media/naranyala/Data";
      #     type = "ext4";
      #     options = "nofail,x-systemd.automount,x-systemd.idle-timeout=60";
      #   }];
      "/media/naranyala/Data/diskd-binaries"
      "/media/naranyala/Data/diskd-binaries/v_linux"
      "/media/naranyala/Data/diskd-binaries/zig-x86_64-linux-0.15.2"
      "/media/naranyala/Data/diskd-binaries/odin-linux"
      "/media/naranyala/Data/diskd-binaries/c3-linux"
    ];
  };

  # ═══════════════════════════════════════════════════════
  # 12. DATABASE — PostgreSQL
  #
  # Runs a PostgreSQL 17 server as a systemd service.
  #   ensureDatabases: creates databases on first activation
  #   ensureUsers: creates roles that can connect
  #   ensurePermissions: grants access to the database
  #
  # Data directory: /var/lib/postgresql/17
  # Backup: pg_dump mydatabase > backup.sql
  # Restore: psql mydatabase < backup.sql
  #
  # FUTURE IMPROVEMENTS:
  #   • Add `services.postgresql.enableTCPIP = true;` and
  #     `services.postgresql.authentication = "scram-sha-256";`
  #     for remote access (with firewall rules!)
  #   • Add `services.postgresql.initialScript` to run custom
  #     SQL on first boot (create schemas, extensions)
  #   • Add Redis for caching: `services.redis.enable = true;`
  #   • Add SQLite: already included as a package (serverless,
  #     no service needed)
  #   • Add MySQL/MariaDB: `services.mysql.enable = true;`
  #   • Add `services.postgresql.backup = { ... };` for
  #     automated pg_dump cron jobs
  # ═══════════════════════════════════════════════════════
  services.postgresql = {
    enable = true;
    package = pkgs.postgresql_17;
    ensureDatabases = [ "mydatabase" ];
    ensureUsers = [{
      name = "myuser";
    }];
    # ensurePermissions = {
    #   "myuser.mydatabase" = "ALL PRIVILEGES";
    # };
  };

  # ═══════════════════════════════════════════════════════
  # 13. ACTIVATION SCRIPTS
  #
  # Activation scripts run on EVERY rebuild, before the new
  # system becomes active. They must be idempotent (safe to
  # run multiple times with the same result).
  #
  # REMOVED: system.activationScripts.myScript
  #   This previously ran `curl | bash` every rebuild — a
  #   security risk (supply chain attack vector) and
  #   non-idempotent (bun install -g fails on re-run).
  #
  # To install Claude CLI and Gemini CLI:
  #   curl -fsSL https://claude.ai/install.sh | bash
  #   bun install -g @google/gemini-cli@latest
  #
  # Or better: wait for proper Nix derivations and add them
  # to environment.systemPackages or home-manager.
  #
  # FUTURE IMPROVEMENTS:
  #   • If you need a one-time setup script, use:
  #       system.activationScripts.mySetup.text = ''
  #         [ -f /path/to/marker ] || {
  #           echo "Running one-time setup..."
  #           touch /path/to/marker
  #         }
  #       '';
  #   • For file sync on rebuild, consider impermanence:
  #       https://github.com/nix-community/impermanence
  # ═══════════════════════════════════════════════════════

  # ═══════════════════════════════════════════════════════
  # 14. SYSTEM-WIDE PROGRAMS
  #
  # `programs.*` options enable features that affect all users.
  # These are higher-level than packages — they configure
  # services, shell integration, and defaults.
  #
  # Firefox: system-wide installation available via GDM login.
  # Starship: cross-shell prompt (git status, lang versions, etc.)
  #
  # FUTURE IMPROVEMENTS:
  #   • Add `programs.zsh.enable = true;` for system-wide zsh
  #     with tab completion and syntax highlighting
  #   • Add `programs.bash.enableCompletion = true;` for
  #     bash tab completion (packages + nix commands)
  #   • Add `programs.nix-ld.enable = true;` — already in §6
  #   • Add `programs.gnupg.agent.enable = true;` for GPG agent
  #     with SSH support (replaces ssh-agent)
  #   • Add `services.devmon.enable = true;` for auto-mounting
  #     USB drives and optical media
  #   • Add `programs.direnv.enable = true;` for per-directory
  #     dev environments (great for multi-project setups)
  #   • Add `services.flatpak.enable = true;` for Flatpak support
  #     (useful for apps not yet packaged in Nix)
  # ═══════════════════════════════════════════════════════
  programs.firefox.enable = true;
  programs.starship.enable = true;
  # programs.starship.enableBashIntegration = true;
  # programs.starship.enableZshIntegration = true;

  # ═══════════════════════════════════════════════════════
  # 15. HOME MANAGER (user-level config)
  #
  # Home Manager manages dotfiles, user packages, and user-level
  # services. It uses the same Nix language but applies to a
  # specific user's home directory (~/.config, ~/.local, etc.).
  #
  # useGlobalPkgs = true  → user packages use the same nixpkgs
  #                           as system (consistent versions)
  # useUserPackages = true → home.packages are installed
  #
  # WHAT BELONGS HERE vs environment.systemPackages:
  #   Home Manager: editors, languages, CLI tools, dotfiles,
  #     user services (git config, ssh config, tmux, starship)
  #   System: browsers, DE extensions, system daemons, drivers
  #
  # FUTURE IMPROVEMENTS:
  #   • Add `home.packages = with pkgs; [ ... ];` for personal
  #     dev tools: nodejs, python, rust, zig, bun, uv, gcc,
  #     clang, llvm, typescript, bat, fzf, ripgrep, btop, etc.
  #   • Add EasyEffects declarative config:
  #       xdg.configFile."EasyEffects/output/equalizer.json".source =
  #         pkgs.writeText "equalizer.json" ''{ ... }'';
  #       xdg.configFile."EasyEffects/input/mic-denoise.json".source =
  #         pkgs.writeText "mic-denoise.json" ''{ ... }'';
  #   • Add git config:
  #       programs.git = {
  #         enable = true;
  #         userName = "naranyala";
  #         userEmail = "naranyala@email.com";
  #         extraConfig = {
  #           init.defaultBranch = "main";
  #           core.editor = "nvim";
  #         };
  #       };
  #   • Add tmux config:
  #       programs.tmux = {
  #         enable = true;
  #         clock24 = true;
  #         keyMode = "vi";
  #         extraConfig = ''
  #           set -g mouse on
  #           bind | split-window -h
  #           bind - split-window -v
  #         '';
  #       };
  #   • Add zsh as shell with plugins:
  #       programs.zsh = {
  #         enable = true;
  #         oh-my-zsh = {
  #           enable = true;
  #           plugins = [ "git" "z" "sudo" ];
  #         };
  #       };
  #   • Add SSH config:
  #       programs.ssh = {
  #         enable = true;
  #         extraConfig = ''
  #           Host github.com
  #             IdentityFile ~/.ssh/id_ed25519
  #         '';
  #       };
  #   • Add Neovim plugins via `programs.neovim.plugins`
  #   • Add `home.file.".foo".source = ./dotfiles/foo;` for
  #     dotfiles not covered by home-manager modules
  #   • Add `services.syncthing.enable = true;` for file sync
  #     between machines (like Dropbox but self-hosted)
  #   • Add `services.gpg-agent.enable = true;` for GPG/SSH agent
  #   • Add `services.mpris-proxy.enable = true;` for Bluetooth
  #     media key control (play/pause from headset)
  #   • Add `home.pointerCursor` to sync cursor theme across
  #     GTK, Qt, and X11 apps:
  #       home.pointerCursor = {
  #         name = "Adwaita";
  #         package = pkgs.adwaita-icon-theme;
  #         gtk.enable = true;
  #         x11.enable = true;
  #       };
  # ═══════════════════════════════════════════════════════
  home-manager = {
    useGlobalPkgs = true;
    useUserPackages = true;

    users.naranyala = { pkgs, config, ... }: {
      home.stateVersion = "25.05";

      home.sessionPath = [
        "${config.home.homeDirectory}/.local/bin"
        "${config.home.homeDirectory}/.bun/bin"
      ];

      home.shellAliases = {
        # NixOS rebuild helpers
        nx-switch = "sudo nixos-rebuild switch";
        nx-edit   = "sudo nvim /etc/nixos/configuration.nix";
        nx-gc     = "sudo nix-collect-garbage -d";
        nx-clean  = "sudo nix-collect-garbage -d && sudo nix-store --optimize";
        update    = "sudo nixos-rebuild switch --upgrade";

        # Quick git
        gs = "git status -sb";
        gp = "git push";

        ll = "ls -la";
      };

      programs.neovim = {
        enable = true;
