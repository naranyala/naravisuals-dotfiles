  # ═══════════════════════════════════════════════════════
  # 16. STATE VERSION
  #
  # DO NOT change this unless you know what you're doing.
  # This tells NixOS which version of the config format was
  # current when this file was created. Changing it on a
  # working system can break things.
  #
  # Only bump when:
  #   • You upgrade to a new NixOS release (25.05 → 25.11)
  #   • The NixOS manual tells you to
  #
#   If you accidentally change it, revert to the original
  #   and run `sudo nixos-rebuild switch` to fix.
  # ═══════════════════════════════════════════════════════

  # OpenGL + CUDA for AI apps and browsers
  hardware.opengl.enable = true;
  services.ollama.enable = true;

  system.stateVersion = "25.05";
