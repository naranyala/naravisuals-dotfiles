{
    "layer": "top",
    "position": "top",
    "height": 34,
    "spacing": 2,
    "modules-left": [
        "custom/window"
    ],
    "modules-center": [],
    "modules-right": [
        "pulseaudio",
        "custom/brightness",
        "custom/network",
        "custom/bandwidth",
        "battery",
        "cpu",
        "memory",
        "temperature",
        "custom/disk",
        "custom/power",
        "clock",
        "tray"
    ],

    "custom/workspaces": {
        "format": "{}",
        "exec": "/home/naranyala/.config/waybar/workspaces.sh",
        "return-type": "json",
        "interval": 1
    },

    "custom/window": {
        "format": "{}",
        "exec": "/home/naranyala/.config/waybar/window_info.sh",
        "return-type": "json",
        "interval": 1
    },

    "custom/disk": {
        "format": "{}",
        "exec": "/home/naranyala/.config/waybar/disk_usage.sh",
        "return-type": "json",
        "interval": 10,
        "on-click": "/home/naranyala/.config/waybar/disk_picker.sh"
    },

    "custom/power": {
        "format": "[ Power ]",
        "on-click": "/home/naranyala/.config/waybar/session_menu.sh"
    },

    "clock": {
        "format": "{:%H:%M}",
        "format-alt": "{:%Y-%m-%d %H:%M}",
        "tooltip-format": "<big>{:%Y %B}</big>\n<tt><small>{calendar}</small></tt>"
    },

    "pulseaudio": {
        "format": "[ audio {volume}% ]",
        "on-click": "pavucontrol"
    },

    "custom/brightness": {
        "format": "[ Brightness ]",
        "on-click": "/home/naranyala/.config/waybar/brightness_menu.sh"
    },

    "custom/network": {
        "format": "{}",
        "exec": "/home/naranyala/.config/waybar/network_status.sh",
        "return-type": "json",
        "interval": 2,
        "on-click": "/home/naranyala/.config/waybar/network_menu.sh"
    },

    "custom/bandwidth": {
        "format": "{}",
        "exec": "/home/naranyala/.config/waybar/bandwidth_monitor.py",
        "return-type": "json",
        "interval": 10,
        "on-click": "/home/naranyala/.config/waybar/bandwidth_monitor.py --toggle"
    },

    "battery": {
        "states": {
            "warning": 30,
            "critical": 15
        },
        "format": "[ battery {capacity}% ]",
        "format-charging": "[ charging {capacity}% ]",
        "format-plugged": "[ plugged {capacity}% ]",
        "format-alt": "[ battery {time} ]"
    },

    "cpu": {
        "format": "[ cpu {usage}% ]",
        "interval": 2,
        "on-click": "ghostty -e btop"
    },

    "memory": {
        "format": "[ mem {percentage}% ]",
        "interval": 2,
        "on-click": "ghostty -e btop"
    },

    "temperature": {
        "critical-threshold": 80,
        "format": "[ temp {temperatureC}°C ]",
        "on-click": "ghostty -e btop"
    },

    "tray": {
        "icon-size": 18,
        "spacing": 10
    }
}
